# ── Anthropic ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Telegram ────────────────────────────────────────────
# Get from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCDEFyour-bot-token

# Your personal Telegram chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=987654321

# ── Schedule (cron syntax) ───────────────────────────────
# Default: 8:00 AM every day
DIGEST_CRON=0 8 * * *

# ── Database path ───────────────────────────────────────
DB_PATH=./data/jobs.db
